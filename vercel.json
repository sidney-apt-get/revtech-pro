{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "VITE_SUPABASE_URL": "@revtech_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@revtech_supabase_anon_key",
    "VITE_GOOGLE_CLIENT_ID": "@revtech_google_client_id"
  }
}
